DATABASE_URL="postgresql://postgres:postgres@localhost:5432/emendare?schema=public"
WEB_ORIGIN="http://localhost:3000"
PORT="4000"
REDIS_URL="redis://localhost:6379"

# --- Ingestion (harvesters) ---
# Cron des runs automatiques (defaut: dimanche 03:00, dumps open data hebdo). "off" pour desactiver.
INGESTION_CRON="0 3 * * 0"
# Legislatures AN a ingerer (separees par des virgules)
AN_LEGISLATURES="17"
# Repertoire de travail des dumps telecharges
DATA_DIR="./data"
# Un ingestor est "stale" si aucun succes depuis N heures (defaut 192 = 8 jours)
INGESTION_STALE_HOURS="192"
# Niveau minimal des logs persistes en DB (DEBUG | INFO | WARN | ERROR)
INGESTION_LOG_LEVEL="INFO"

# --- Legifrance / droit consolide (dumps DILA locaux, souverain — PAS l'API PISTE) ---
# URLs des fonds officiels DILA (echanges.dila.gouv.fr/OPENDATA/). Vides = etape ignoree
# (le reste de l'app fonctionne ; les renvois restent non resolus). Fond LEGI = codes/articles
# consolides (droit en vigueur, cible du diff) ; JORF = lois promulguees (LFSS/LFI N-1).
# Le "global" LEGI est volumineux (~Go) : prevoir l'espace disque cote serveur.
LEGIFRANCE_LEGI_URL=""
LEGIFRANCE_JORF_URL=""

# --- Embeddings (similarite pgvector) ---
# Cle API du fournisseur d'embeddings (OpenRouter aujourd'hui). Vide = endpoints de similarite en 503.
EMBEDDING_API_KEY=""
# Toute gateway compatible OpenAI (/v1/embeddings) convient : OpenRouter, api.openai.com, serveur local demain.
EMBEDDING_BASE_URL="https://openrouter.ai/api/v1"
# Changer de modele => re-embedder (l'ingestor amendment-embeddings re-traite tout mismatch embeddingModel).
EMBEDDING_MODEL="openai/text-embedding-3-small"
# Doit correspondre a la dimension de la colonne vector() en DB (migration a refaire si change).
EMBEDDING_DIM="1536"
# Textes par appel API (batch)
EMBEDDING_BATCH_SIZE="200"

# --- Agent recevabilite (etage LLM G5 — docs/metier/procedure-recevabilite-agent.md) ---
# Cle API de la gateway LLM. Vide = retombe sur EMBEDDING_API_KEY (meme compte OpenRouter).
# Sans aucune cle : les gates deterministes fonctionnent, l'examen approfondi est marque indisponible.
REVIEWER_API_KEY=""
# Gateway compatible OpenAI (/v1/chat/completions). Vide = retombe sur EMBEDDING_BASE_URL.
REVIEWER_BASE_URL=""
# Modele de l'examen G5 (slug OpenRouter). Demarre sur DeepSeek (economique) ; changer librement.
REVIEWER_MODEL="deepseek/deepseek-chat"
