# Copier vers .env.prod puis remplir :
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Domaines routés par Traefik
WEB_HOST=emendare.fr
API_HOST=api.emendare.fr

# Nom du réseau docker externe auquel le Traefik de l'hôte est attaché
TRAEFIK_NETWORK=proxy

# Secrets
POSTGRES_PASSWORD=''

# Embeddings (similarité pgvector) — clé OpenRouter (ou autre gateway compatible OpenAI)
EMBEDDING_API_KEY='sk-or-v1-'
# Optionnels (défauts dans docker-compose.prod.yml) :
#EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
#EMBEDDING_MODEL=openai/text-embedding-3-small
#EMBEDDING_DIM=1536

# --- Droit consolidé Légifrance ---
# Décision 2026-07-04 (bis) : dumps DILA ABANDONNÉS (global figé à 2025-07-13, deltas non gérés).
# Remplacement prévu : récupération À LA VOLÉE de l'article visé via l'API Légifrance (PISTE),
# à partir des TextReference (code + article) extraites de l'amendement.
# Laisser vide = étape textes-legifrance ignorée proprement (renvois captés, non résolus).
LEGIFRANCE_LEGI_URL=''
LEGIFRANCE_JORF_URL=''

# Ingestion — optionnels (defaults sûrs dans le code) :
#INGESTION_CRON='0 3 * * 0'   # cron des runs auto ; "off" pour désactiver
#AN_LEGISLATURES='17'         # législatures AN à ingérer (séparées par virgules)
